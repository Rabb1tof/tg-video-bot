# ── Обязательные ──────────────────────────────────────────────────────────────

# Токен бота от @BotFather
TELEGRAM_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# API ID и Hash для локального Bot API сервера
# Получить на https://my.telegram.org/apps
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890

# ID приватного канала для хранения видео (бот должен быть администратором)
# Чтобы узнать ID: перешли любое сообщение из канала боту @userinfobot
STORAGE_CHANNEL_ID=-1001234567890

# ── Опциональные (значения по умолчанию) ─────────────────────────────────────

# Количество параллельных воркеров скачивания
WORKER_COUNT=5

# Максимальный размер файла в МБ
MAX_FILE_SIZE_MB=500

# TTL кэша в днях
CACHE_TTL_DAYS=30

# Лимит запросов на пользователя в час
RATE_LIMIT_PER_HOUR=5

# Уровень логирования: info | debug
LOG_LEVEL=info

# Пароль Redis (оставь пустым если без пароля)
REDIS_PASSWORD=

# ── Авторизация платформ ──────────────────────────────────────────────────────

# Путь к файлу cookies внутри контейнера (Netscape-формат, экспорт из браузера).
# Используется для VK, TikTok и других платформ, требующих авторизации.
# Как получить: установи расширение "Get cookies.txt LOCALLY" (Chrome/Firefox),
# зайди на vk.com / tiktok.com под своим аккаунтом и экспортируй cookies.txt.
# Положи файл в ./cookies/cookies.txt на сервере, затем укажи путь внутри контейнера:
COOKIES_FILE=/cookies/cookies.txt

# ВКонтакте: логин и пароль (альтернатива cookies, работает только если VK не
# заблокировал вход по паролю из вашего региона/IP)
VK_USERNAME=
VK_PASSWORD=
